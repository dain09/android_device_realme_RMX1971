###############################################
# SELinux Policy — HAL DRM (Widevine)
# Maintainer: Abdallah Ibrahim <D_ai_n@telegram>
###############################################

# Define executable type for HAL DRM service
#type hal_drm_widevine_exec, exec_type, file_type, vendor_file_type;

# Allow only safe firmware file access
allow hal_drm firmware_file:file { read getattr open };

