# SELinux rules for HAL DRM (Widevine)

#type hal_drm, domain;
type hal_drm_exec, exec_type, file_type;

# Allow basic file access
allow hal_drm firmware_file:file { read getattr open };

# Optional (حسب الحاجة):
# allow hal_drm sysfs:file { read open getattr };
# allow hal_drm self:process { execmem };  # لو كان مطلوب للتنفيذ

# Note:
# intentionally excluded 'watch' and 'watch_reads' to pass neverallow check